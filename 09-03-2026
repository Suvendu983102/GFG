class Solution:
    def countSubarrays(self, arr):
        n = len(arr)
        # nse[i] stores the index of the first element to the right of i 
        # that is strictly smaller than arr[i].
        # Initialize with n, representing the "out of bounds" index.
        nse = [n] * n
        stack = []
        
        # Traverse from right to left to find the next smaller element
        for i in range(n - 1, -1, -1):
            # Maintain a monotonic increasing stack (bottom to top)
            # Pop elements that are greater than or equal to current
            while stack and arr[stack[-1]] >= arr[i]:
                stack.pop()
            
            # If stack is not empty, the top is the next smaller element index
            if stack:
                nse[i] = stack[-1]
            
            stack.append(i)
        
        # The number of valid subarrays starting at index i is (nse[i] - i)
        total_count = 0
        for i in range(n):
            total_count += (nse[i] - i)
            
        return total_count
